{
  "family": "carddemo-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/carddemo-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/carddemo-ecs-task-role",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "carddemo-api",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/carddemo-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "APP_NAME",
          "value": "carddemo"
        },
        {
          "name": "APP_VERSION",
          "value": "1.0.0"
        },
        {
          "name": "LOG_LEVEL",
          "value": "INFO"
        },
        {
          "name": "AWS_REGION",
          "value": "us-east-1"
        },
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "JWT_ALGORITHM",
          "value": "HS256"
        },
        {
          "name": "JWT_ACCESS_TOKEN_EXPIRE_MINUTES",
          "value": "30"
        },
        {
          "name": "DB_SECRET_NAME",
          "value": "carddemo/aurora-credentials"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:carddemo/aurora-credentials:DATABASE_URL::"
        },
        {
          "name": "DATABASE_URL_SYNC",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:carddemo/aurora-credentials:DATABASE_URL_SYNC::"
        },
        {
          "name": "JWT_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:carddemo/jwt-secret:JWT_SECRET_KEY::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/carddemo-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:80/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "readonlyRootFilesystem": false,
      "privileged": false,
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 65536,
          "hardLimit": 65536
        }
      ],
      "stopTimeout": 30
    }
  ],
  "tags": [
    {
      "key": "project",
      "value": "carddemo"
    },
    {
      "key": "workload",
      "value": "api"
    },
    {
      "key": "runtime",
      "value": "python-3.11-fastapi"
    },
    {
      "key": "source",
      "value": "CBADMCDJ.jcl"
    },
    {
      "key": "replaces",
      "value": "CICS-region"
    },
    {
      "key": "environment",
      "value": "production"
    }
  ]
}

# ============================================================================
# CardDemo — Git ignore patterns
# ============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
.hypothesis/
nosetests.xml
junit.xml

# ---------------------------------------------------------------------------
# Environment variables / secrets (never commit these)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker / docker-compose local state
# ---------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------------
# PySpark / Spark local state
# ---------------------------------------------------------------------------
spark-warehouse/
metastore_db/
derby.log

# ---------------------------------------------------------------------------
# AWS / Terraform / local infrastructure state
# ---------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.backup

# ---------------------------------------------------------------------------
# Node.js (not used by this project but ignored defensively)
# ---------------------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------------------
# Blitzy platform working directory
# ---------------------------------------------------------------------------
# (kept in-repo for screenshots but ignore ad-hoc test artifacts)
blitzy/**/blitzy_adhoc_test_*

*---------------------------------------------------------------*
* BMS SOURCE: COTRN00 - Transaction List Screen
*---------------------------------------------------------------*
* This BMS source defines the Transaction List screen used by
* online program COTRN00C (CICS transaction CT00).
*
* The screen displays a paginated, filterable list of credit
* card transactions with 10 selectable data rows per page.
* Users can page forward (F8) and backward (F7) through the
* result set and filter by Transaction ID via a search input.
*
*   Mapset : COTRN00
*   Map    : COTRN0A
*   Program: COTRN00C  (Source: app/cbl/COTRN00C.cbl)
*   Tran ID: CT00
*   Symbolic map copybook: app/cpy-bms/COTRN00.CPY
*
* Screen layout (24 rows x 80 columns):
*   Row  1-2 : Standard header (Tran/Prog/Title/Date/Time)
*   Row  4   : Screen title "List Transactions" + page number
*   Row  6   : Transaction ID search filter input
*   Row  8   : Column header labels
*   Row  9   : Column separator dashes
*   Row 10-19: 10 data rows (Sel, Tran ID, Date, Desc, Amt)
*   Row 21   : Informational message / user guidance
*   Row 23   : Error message area (78-char, RED)
*   Row 24   : Function key legend (Enter/F3/F7/F8)
*---------------------------------------------------------------*
*
*---------------------------------------------------------------*
* DFHMSD - Mapset definition for COTRN00
*---------------------------------------------------------------*
* CTRL=(ALARM,FREEKB): Sound alarm on SEND, free keyboard
* EXTATT=YES:          Enable extended attributes (color, etc.)
* LANG=COBOL:          Generate COBOL symbolic map copybook
* MODE=INOUT:          Map supports both input and output
* STORAGE=AUTO:        Automatic storage allocation per task
* TIOAPFX=YES:         Include 12-byte TIOA prefix in map I/O
* TYPE=&&SYSPARM:      Map type set via assembly SYSPARM parm
*---------------------------------------------------------------*
COTRN00 DFHMSD CTRL=(ALARM,FREEKB),                                    -
               EXTATT=YES,                                             -
               LANG=COBOL,                                             -
               MODE=INOUT,                                             -
               STORAGE=AUTO,                                           -
               TIOAPFX=YES,                                            -
               TYPE=&&SYSPARM
*---------------------------------------------------------------*
* DFHMDI - Map COTRN0A definition
*---------------------------------------------------------------*
* Defines a single 24-row by 80-column 3270 screen map.
* COLUMN=1, LINE=1: Map starts at top-left corner of screen.
* SIZE=(24,80): Full standard 3270 Model 2 terminal screen.
*---------------------------------------------------------------*
COTRN0A DFHMDI COLUMN=1,                                               -
               LINE=1,                                                 -
               SIZE=(24,80)
*---------------------------------------------------------------*
* HEADER AREA - Screen rows 1-2
*---------------------------------------------------------------*
* Standard CardDemo header present on all application screens.
* All header fields are ASKIP (auto-skip, protected) so the
* user cannot modify them.
*
* Row 1 layout:
*   Col  1: "Tran:" label (BLUE) + TRNNAME (4-char tran ID)
*   Col 21: TITLE01 (40-char application title line 1, YELLOW)
*   Col 65: "Date:" label (BLUE) + CURDATE (8-char mm/dd/yy)
*
* Row 2 layout:
*   Col  1: "Prog:" label (BLUE) + PGMNAME (8-char program)
*   Col 21: TITLE02 (40-char application title line 2, YELLOW)
*   Col 65: "Time:" label (BLUE) + CURTIME (8-char hh:mm:ss)
*---------------------------------------------------------------*
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=BLUE,                                             -
               LENGTH=5,                                               -
               POS=(1,1),                                              -
               INITIAL='Tran:'
TRNNAME DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=4,                                               -
               POS=(1,7)
TITLE01 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=YELLOW,                                           -
               LENGTH=40,                                              -
               POS=(1,21)
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=BLUE,                                             -
               LENGTH=5,                                               -
               POS=(1,65),                                             -
               INITIAL='Date:'
CURDATE DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=8,                                               -
               POS=(1,71),                                             -
               INITIAL='mm/dd/yy'
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=BLUE,                                             -
               LENGTH=5,                                               -
               POS=(2,1),                                              -
               INITIAL='Prog:'
PGMNAME DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=8,                                               -
               POS=(2,7)
TITLE02 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=YELLOW,                                           -
               LENGTH=40,                                              -
               POS=(2,21)
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=BLUE,                                             -
               LENGTH=5,                                               -
               POS=(2,65),                                             -
               INITIAL='Time:'
CURTIME DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=8,                                               -
               POS=(2,71),                                             -
               INITIAL='hh:mm:ss'
*---------------------------------------------------------------*
* SCREEN TITLE AND PAGE NUMBER - Row 4
*---------------------------------------------------------------*
* Centered title "List Transactions" in bright neutral color.
* Right side shows "Page:" label (TURQUOISE) with PAGENUM
* dynamic field for the current page number in the paginated
* browse sequence. PAGENUM is populated by COTRN00C at runtime.
*---------------------------------------------------------------*
        DFHMDF ATTRB=(ASKIP,BRT),                                      -
               COLOR=NEUTRAL,                                          -
               LENGTH=17,                                              -
               POS=(4,30),                                             -
               INITIAL='List Transactions'
        DFHMDF ATTRB=(ASKIP,BRT),                                      -
               COLOR=TURQUOISE,                                        -
               LENGTH=5,                                               -
               POS=(4,65),                                             -
               INITIAL='Page:'
PAGENUM DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=8,                                               -
               POS=(4,71),                                             -
               INITIAL=' '
*---------------------------------------------------------------*
* SEARCH FILTER - Row 6
*---------------------------------------------------------------*
* Transaction ID search filter area. The "Search Tran ID:"
* label (TURQUOISE) precedes TRNIDIN, a 16-character unprotected
* input field (UNPROT, GREEN, UNDERLINE) where the user can
* type a transaction ID prefix to filter the displayed list.
* A zero-length stopper field (ASKIP) follows at POS=(6,38)
* to delimit the input area and prevent cursor overrun.
*---------------------------------------------------------------*
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=TURQUOISE,                                        -
               LENGTH=15,                                              -
               POS=(6,5),                                              -
               INITIAL='Search Tran ID:'
TRNIDIN DFHMDF ATTRB=(FSET,NORM,UNPROT),                               -
               COLOR=GREEN,                                            -
               HILIGHT=UNDERLINE,                                      -
               LENGTH=16,                                              -
               POS=(6,21)
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               LENGTH=0,                                               -
               POS=(6,38)
*---------------------------------------------------------------*
* COLUMN HEADERS - Row 8
*---------------------------------------------------------------*
* Column header labels for the transaction data grid.
* All headers are ASKIP (protected), NEUTRAL color.
*   Col  2: "Sel"              (3 chars)  - Selection indicator
*   Col  8: " Transaction ID " (16 chars) - Unique tran ID
*   Col 27: "  Date  "         (8 chars)  - Transaction date
*   Col 38: "     Description" (26 chars) - Description text
*   Col 67: "   Amount   "    (12 chars)  - Transaction amount
*---------------------------------------------------------------*
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=3,                                               -
               POS=(8,2),                                              -
               INITIAL='Sel'
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=16,                                              -
               POS=(8,8),                                              -
               INITIAL=' Transaction ID '
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=8,                                               -
               POS=(8,27),                                             -
               INITIAL='  Date  '
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=26,                                              -
               POS=(8,38),                                             -
               INITIAL='     Description          '
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=12,                                              -
               POS=(8,67),                                             -
               INITIAL='   Amount   '
*---------------------------------------------------------------*
* COLUMN SEPARATORS - Row 9
*---------------------------------------------------------------*
* Dash separator line under column headers for visual
* alignment. Each dash group matches the width of its
* corresponding column above. All are ASKIP, NEUTRAL.
*---------------------------------------------------------------*
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=3,                                               -
               POS=(9,2),                                              -
               INITIAL='---'
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=16,                                              -
               POS=(9,8),                                              -
               INITIAL='----------------'
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=8,                                               -
               POS=(9,27),                                             -
               INITIAL='--------'
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=26,                                              -
               POS=(9,38),                                             -
               INITIAL='--------------------------'
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=NEUTRAL,                                          -
               LENGTH=12,                                              -
               POS=(9,67),                                             -
               INITIAL='------------'
*---------------------------------------------------------------*
* DATA ROWS - Rows 10-19 (10 repeating row groups)
*---------------------------------------------------------------*
* Each row occupies one screen line and contains 5 fields:
*
*   SELnnnn  - 1-char UNPROT selection field (GREEN, UNDERLINE)
*              User types 'S' to select a transaction for
*              detail view. Followed by a 0-length ASKIP
*              stopper field to delimit input.
*   TRNIDnn  - 16-char transaction ID display (ASKIP, BLUE)
*   TDATEnn  - 8-char transaction date display (ASKIP, BLUE)
*   TDESCnn  - 26-char transaction description (ASKIP, BLUE)
*   TAMTnnn  - 12-char transaction amount (ASKIP, BLUE)
*
* Field naming convention (suffix = row number):
*   SEL   uses 4-digit suffix: SEL0001 through SEL0010
*   TRNID uses 2-digit suffix: TRNID01 through TRNID10
*   TDATE uses 2-digit suffix: TDATE01 through TDATE10
*   TDESC uses 2-digit suffix: TDESC01 through TDESC10
*   TAMT  uses 3-digit suffix: TAMT001 through TAMT010
*
* All display fields are ASKIP/FSET (auto-skip, field-set).
* All selection fields are FSET/UNPROT with UNDERLINE highlight.
* Row layout per line:
*   Col 3: Sel | Col 8: Tran ID | Col 27: Date |
*   Col 38: Description | Col 67: Amount
*---------------------------------------------------------------*
* --- Data Row 01 (screen row 10) ---
SEL0001 DFHMDF ATTRB=(FSET,NORM,UNPROT),                               -
               COLOR=GREEN,                                            -
               HILIGHT=UNDERLINE,                                      -
               LENGTH=1,                                               -
               POS=(10,3),                                             -
               INITIAL=' '
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               LENGTH=0,                                               -
               POS=(10,5)
TRNID01 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=16,                                              -
               POS=(10,8),                                             -
               INITIAL=' '
TDATE01 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=8,                                               -
               POS=(10,27),                                            -
               INITIAL=' '
TDESC01 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=26,                                              -
               POS=(10,38),                                            -
               INITIAL=' '
TAMT001 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=12,                                              -
               POS=(10,67),                                            -
               INITIAL=' '
* --- Data Row 02 (screen row 11) ---
SEL0002 DFHMDF ATTRB=(FSET,NORM,UNPROT),                               -
               COLOR=GREEN,                                            -
               HILIGHT=UNDERLINE,                                      -
               LENGTH=1,                                               -
               POS=(11,3),                                             -
               INITIAL=' '
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               LENGTH=0,                                               -
               POS=(11,5)
TRNID02 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=16,                                              -
               POS=(11,8),                                             -
               INITIAL=' '
TDATE02 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=8,                                               -
               POS=(11,27),                                            -
               INITIAL=' '
TDESC02 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=26,                                              -
               POS=(11,38),                                            -
               INITIAL=' '
TAMT002 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=12,                                              -
               POS=(11,67),                                            -
               INITIAL=' '
* --- Data Row 03 (screen row 12) ---
SEL0003 DFHMDF ATTRB=(FSET,NORM,UNPROT),                               -
               COLOR=GREEN,                                            -
               HILIGHT=UNDERLINE,                                      -
               LENGTH=1,                                               -
               POS=(12,3),                                             -
               INITIAL=' '
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               LENGTH=0,                                               -
               POS=(12,5)
TRNID03 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=16,                                              -
               POS=(12,8),                                             -
               INITIAL=' '
TDATE03 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=8,                                               -
               POS=(12,27),                                            -
               INITIAL=' '
TDESC03 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=26,                                              -
               POS=(12,38),                                            -
               INITIAL=' '
TAMT003 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=12,                                              -
               POS=(12,67),                                            -
               INITIAL=' '
* --- Data Row 04 (screen row 13) ---
SEL0004 DFHMDF ATTRB=(FSET,NORM,UNPROT),                               -
               COLOR=GREEN,                                            -
               HILIGHT=UNDERLINE,                                      -
               LENGTH=1,                                               -
               POS=(13,3),                                             -
               INITIAL=' '
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               LENGTH=0,                                               -
               POS=(13,5)
TRNID04 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=16,                                              -
               POS=(13,8),                                             -
               INITIAL=' '
TDATE04 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=8,                                               -
               POS=(13,27),                                            -
               INITIAL=' '
TDESC04 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=26,                                              -
               POS=(13,38),                                            -
               INITIAL=' '
TAMT004 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=12,                                              -
               POS=(13,67),                                            -
               INITIAL=' '
* --- Data Row 05 (screen row 14) ---
SEL0005 DFHMDF ATTRB=(FSET,NORM,UNPROT),                               -
               COLOR=GREEN,                                            -
               HILIGHT=UNDERLINE,                                      -
               LENGTH=1,                                               -
               POS=(14,3),                                             -
               INITIAL=' '
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               LENGTH=0,                                               -
               POS=(14,5)
TRNID05 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=16,                                              -
               POS=(14,8),                                             -
               INITIAL=' '
TDATE05 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=8,                                               -
               POS=(14,27),                                            -
               INITIAL=' '
TDESC05 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=26,                                              -
               POS=(14,38),                                            -
               INITIAL=' '
TAMT005 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=12,                                              -
               POS=(14,67),                                            -
               INITIAL=' '
* --- Data Row 06 (screen row 15) ---
SEL0006 DFHMDF ATTRB=(FSET,NORM,UNPROT),                               -
               COLOR=GREEN,                                            -
               HILIGHT=UNDERLINE,                                      -
               LENGTH=1,                                               -
               POS=(15,3),                                             -
               INITIAL=' '
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               LENGTH=0,                                               -
               POS=(15,5)
TRNID06 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=16,                                              -
               POS=(15,8),                                             -
               INITIAL=' '
TDATE06 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -

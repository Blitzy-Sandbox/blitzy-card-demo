TAMT010 DFHMDF ATTRB=(ASKIP,FSET,NORM),                                -
               COLOR=BLUE,                                             -
               LENGTH=12,                                              -
               POS=(19,67),                                            -
               INITIAL=' '
*---------------------------------------------------------------*
* INFORMATIONAL MESSAGE - Row 21
*---------------------------------------------------------------*
* Static guidance text instructing the user to type 'S' in a
* row selection field to view that transaction's details.
* ASKIP/BRT (bright), NEUTRAL color, 50 characters wide,
* centered at column 12.
*---------------------------------------------------------------*

        DFHMDF ATTRB=(ASKIP,BRT),                                      -
               COLOR=NEUTRAL,                                          -
               LENGTH=50,                                              -
               POS=(21,12),                                            -
               INITIAL='Type ''S'' to View Transaction details from the-
                list'
*---------------------------------------------------------------*
* ERROR MESSAGE - Row 23
*---------------------------------------------------------------*
* ERRMSG: 78-character error/status message field at row 23.
* RED color, BRT (bright), FSET (field-set on SEND).
* Populated by COTRN00C when validation errors, I/O errors,
* or informational status messages need to be displayed.
* Spans nearly the full screen width for detailed messages.
*---------------------------------------------------------------*
ERRMSG  DFHMDF ATTRB=(ASKIP,BRT,FSET),                                 -
               COLOR=RED,                                              -
               LENGTH=78,                                              -
               POS=(23,1)
*---------------------------------------------------------------*
* FUNCTION KEY LEGEND - Row 24
*---------------------------------------------------------------*
* Bottom-of-screen key legend showing available actions:
*   ENTER    = Continue / confirm selection
*   F3       = Back (return to previous screen)
*   F7       = Backward (page up in the transaction list)
*   F8       = Forward (page down in the transaction list)
* ASKIP/NORM, YELLOW color, 48 characters at row 24 col 1.
*---------------------------------------------------------------*
        DFHMDF ATTRB=(ASKIP,NORM),                                     -
               COLOR=YELLOW,                                           -
               LENGTH=48,                                              -
               POS=(24,1),                                             -
               INITIAL='ENTER=Continue  F3=Back  F7=Backward  F8=Forwar-
               d'
*---------------------------------------------------------------*
* END OF MAP DEFINITION
*---------------------------------------------------------------*
        DFHMSD TYPE=FINAL
